# Ansible inventory generated by Terraform

[pi]
%{ for name, node in pi_nodes ~}
${node.hostname} ansible_host=${split("/", node.static_ip)[0]} mac_address=${node.mac_address}
%{ endfor ~}

[pi:vars]
ansible_user=ansible
ansible_python_interpreter=/usr/bin/python3
ansible_private_key_file=/workspaces/devops-home-lab/ansible_homelab
ansible_ssh_common_args='-o StrictHostKeyChecking=no -o IdentitiesOnly=yes'
ansible_become_method=sudo
podman_rootless_user=containers